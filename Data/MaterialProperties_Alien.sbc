          <SoundCue>ArcBotBeastWalk</SoundCue>
          <ParticleEffect>CharacterStepMarsSoil</ParticleEffect>
          <ParticleProperties>
            <ColorMultiplier>
              <X>2.0</X>
              <Y>1.0</Y>
              <Z>1.0</Z>
              <W>3.0</W>
            </ColorMultiplier>
            <SizeMultiplier>10</SizeMultiplier>
            <Preload>0.0</Preload>
          </ParticleProperties>
        </ContactProperty>
        <ContactProperty>
          <Type>Run</Type>
          <Material>MoonSoil</Material>
          <SoundCue>ArcBotBeastWalk</SoundCue>
          <ParticleEffect>CharacterStepMoonSoil</ParticleEffect>
          <ParticleProperties>
            <ColorMultiplier>
              <X>0.8</X>
              <Y>1.0</Y>
              <Z>1.0</Z>
              <W>3.0</W>
            </ColorMultiplier>
            <SizeMultiplier>10</SizeMultiplier>
            <Preload>0.0</Preload>
          </ParticleProperties>
        </ContactProperty>
        <ContactProperty>
          <Type>Run</Type>
          <Material>Sand</Material>
          <SoundCue>ArcBotBeastWalk</SoundCue>
        </ContactProperty>
        <ContactProperty>
          <Type>Run</Type>
          <Material>Soil</Material>
          <SoundCue>ArcBotBeastWalk</SoundCue>
        </ContactProperty>
        <ContactProperty>
          <Type>Run</Type>
          <Material>SoilDry</Material>
          <SoundCue>ArcBotBeastWalk</SoundCue>
        </ContactProperty>
        <ContactProperty>
          <Type>Run</Type>
          <Material>Metal</Material>
          <SoundCue>ArcBotBeastWalk</SoundCue>
        </ContactProperty>
      </ContactProperties>
    </Properties>

   		<!--rifle bullet-->
    <Properties>
			<Id>
				<TypeId>PhysicalMaterialDefinition</TypeId>
				<SubtypeId>RifleBullet</SubtypeId>
			</Id>
      <ContactProperties>
        <ContactProperty>
          <Type>Hit</Type>
          <Material>LargeAnimal</Material>
          <SoundCue>WepPlayRifleImpPlay</SoundCue>
          <ParticleEffect>Blood_LargeAnimal</ParticleEffect>
        </ContactProperty>
       </ContactProperties>
		</Properties>
    
    <!--gun bullet-->
    <Properties>
			<Id>
				<TypeId>PhysicalMaterialDefinition</TypeId>
				<SubtypeId>GunBullet</SubtypeId>
			</Id>
      <ContactProperties>
        
        <ContactProperty>
