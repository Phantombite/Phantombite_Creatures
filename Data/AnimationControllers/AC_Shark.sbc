            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Any</Name>
            <EdPos>
              <X>212</X>
              <Y>140</Y>
            </EdPos>
            <Type>AnyExceptTarget</Type>
            <Variables />
          </Node>
        </Nodes>
        <Transitions>
          <Transition From="Attack" To="Attack_Bite" TimeInSec="0" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Op="AlwaysTrue" />
              </Conjunction>
            </Conditions>
            <Priority>1</Priority>
          </Transition>
          <Transition From="Attack" To="Attack_Swipe" TimeInSec="0" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Op="AlwaysTrue" />
              </Conjunction>
            </Conditions>
            <Priority>2</Priority>
          </Transition>
        </Transitions>
