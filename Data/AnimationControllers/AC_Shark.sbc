                <PathToModel>Models\Characters\Animations\Shark_Idle.mwm</PathToModel>
                <AnimationName>Big beast-3_Idle</AnimationName>
                <Loop>false</Loop>
                <Speed>1</Speed>
                <Interpolate>true</Interpolate>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>-266</X>
              <Y>-88</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Howling</Name>
            <AnimationTree>
              <EdPos>
                <X>-91</X>
                <Y>62</Y>
              </EdPos>
              <Child xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                <EdPos>
                  <X>94</X>
                  <Y>-11</Y>
                </EdPos>
                <PathToModel>Models\Characters\Animations\Shark_Idle.mwm</PathToModel>
                <Loop>false</Loop>
                <Speed>1</Speed>
                <Interpolate>true</Interpolate>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>150</X>
              <Y>-84</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Any</Name>
            <EdPos>
              <X>-53</X>
              <Y>20</Y>
            </EdPos>
            <Type>Any</Type>
            <Variables />
          </Node>
          <Node>
            <Name>IdleToHowl</Name>
            <AnimationTree>
              <EdPos>
                <X>0</X>
                <Y>0</Y>
              </EdPos>
              <Child xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                <EdPos>
                  <X>260</X>
                  <Y>13</Y>
                </EdPos>
                <PathToModel>Models\Characters\Animations\Shark_Idle.mwm</PathToModel>
                <Loop>true</Loop>
                <Speed>1</Speed>
                <Interpolate>true</Interpolate>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>-59</X>
              <Y>-182</Y>
            </EdPos>
            <Type>PassThrough</Type>
            <Variables />
          </Node>
        </Nodes>
        <Transitions>
          <Transition From="Howling" To="Idle1" TimeInSec="0.3" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="@animationfinished" Op="GreaterOrEqual" Rhs="1" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="Idle1" To="IdleToHowl" TimeInSec="0" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="@animationfinished" Op="GreaterOrEqual" Rhs="1" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="IdleToHowl" To="Howling" TimeInSec="0.1" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="@randomstable" Op="Less" Rhs="0.2" />
              </Conjunction>
            </Conditions>
            <Priority>1</Priority>
          </Transition>
          <Transition From="IdleToHowl" To="Idle1" TimeInSec="0" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Op="AlwaysTrue" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
        </Transitions>
      </StateMachine>
      <StateMachine>
        <Name>SMAttack</Name>
        <Nodes>
          <Node>
            <Name>Attack</Name>
            <EdPos>
              <X>-18</X>
              <Y>-14</Y>
            </EdPos>
            <Type>PassThrough</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Attack_Bite</Name>
            <AnimationTree>
