    </StateMachines>
    <FootIkChains>
      <FootIkChain>
        <FootBone>BeastLFrontLegPalm2</FootBone>
        <ChainLength>3</ChainLength>
        <AlignBoneWithTerrain>true</AlignBoneWithTerrain>
      </FootIkChain>
      <FootIkChain>
        <FootBone>BeastRFrontLegPalm2</FootBone>
        <ChainLength>3</ChainLength>
        <AlignBoneWithTerrain>true</AlignBoneWithTerrain>
      </FootIkChain>
      <FootIkChain>
        <FootBone>BeastLRearLegAnkle2</FootBone>
        <ChainLength>3</ChainLength>
        <AlignBoneWithTerrain>true</AlignBoneWithTerrain>
      </FootIkChain>
      <FootIkChain>
        <FootBone>BeastRRearLegAnkle2</FootBone>
        <ChainLength>3</ChainLength>
        <AlignBoneWithTerrain>true</AlignBoneWithTerrain>
