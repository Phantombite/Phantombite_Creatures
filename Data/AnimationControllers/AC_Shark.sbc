                </EdPos>
                <PathToModel>Models\Characters\Animations\Shark_Attack2.mwm</PathToModel>
                <AnimationName>Big beast-3 - attack2</AnimationName>
                <Loop>false</Loop>
                <Speed>1</Speed>
                <Interpolate>true</Interpolate>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>-331</X>
