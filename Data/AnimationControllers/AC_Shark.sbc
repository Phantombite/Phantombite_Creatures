<?xml version="1.0"?>
<Definitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Definition xsi:type="AnimationControllerDefinition">
    <Id Type="MyObjectBuilder_AnimationControllerDefinition" Subtype="Shark" />
    <Layers>
      <Layer>
        <Name>Beast_Body</Name>
        <Mode>Replace</Mode>
        <StateMachine>SMBeast_Body</StateMachine>
        <InitialSMNode>Start</InitialSMNode>
      </Layer>
    </Layers>
    <StateMachines>
      <StateMachine>
        <Name>SMBeast_Body</Name>
        <Nodes>
          <Node>
            <Name>Move</Name>
            <AnimationTree>
              <EdPos>
                <X>-278</X>
                <Y>-46</Y>
              </EdPos>
              <Child xsi:type="MyObjectBuilder_AnimationTreeNodeMix1D">
                <EdPos>
                  <X>-11</X>
                  <Y>-14</Y>
                </EdPos>
                <ParameterName>speed</ParameterName>
                <Circular>false</Circular>
                <Sensitivity>1</Sensitivity>
                <MaxChange xsi:nil="true" />
                <Child>
                  <Param>3</Param>
                  <Node xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                    <EdPos>
                      <X>475</X>
                      <Y>-160</Y>
                    </EdPos>
                    <PathToModel>Models\Characters\Animations\Shark_Walk.mwm</PathToModel>
                    <AnimationName>AnimStack::Big beast-3</AnimationName>
                    <Loop>true</Loop>
                    <Speed>1</Speed>
                    <Interpolate>true</Interpolate>
                  </Node>
                </Child>
                <Child>
                  <Param>6.5</Param>
                  <Node xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                    <EdPos>
                      <X>468</X>
                      <Y>105</Y>
                    </EdPos>
                    <PathToModel>Models\Characters\Animations\Shark_Walk.mwm</PathToModel>
                    <AnimationName>AnimStack::Big beast-3</AnimationName>
                    <Loop>true</Loop>
                    <Speed>1</Speed>
                    <Interpolate>true</Interpolate>
                  </Node>
                </Child>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>450</X>
              <Y>10</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Death</Name>
            <AnimationTree>
              <EdPos>
                <X>0</X>
                <Y>0</Y>
              </EdPos>
              <Child xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                <EdPos>
                  <X>453</X>
                  <Y>-49</Y>
                </EdPos>
                <PathToModel>Models\Characters\Animations\Shark_Death.mwm</PathToModel>
                <Loop>false</Loop>
                <Speed>2</Speed>
                <Interpolate>true</Interpolate>
              </Child>
            </AnimationTree>
            <EdPos>
              <X>450</X>
              <Y>380</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>all</Name>
            <EdPos>
              <X>419</X>
              <Y>223</Y>
            </EdPos>
            <Type>AnyExceptTarget</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Idle</Name>
            <StateMachineName>SMIdle</StateMachineName>
            <EdPos>
              <X>-41</X>
              <Y>24</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Start</Name>
            <EdPos>
              <X>-30</X>
              <Y>-81</Y>
            </EdPos>
            <Type>PassThrough</Type>
            <Variables />
          </Node>
          <Node>
            <Name>Attack</Name>
            <StateMachineName>SMAttack</StateMachineName>
            <EdPos>
              <X>7</X>
              <Y>306</Y>
            </EdPos>
            <Type>Normal</Type>
            <Variables />
          </Node>
        </Nodes>
        <Transitions>
          <Transition From="all" To="Death" TimeInSec="0.2" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="dead" Op="Equal" Rhs="1" />
              </Conjunction>
            </Conditions>
            <Priority>1</Priority>
          </Transition>
          <Transition From="Move" To="Idle/Idle1" TimeInSec="0.3" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="Speed" Op="Less" Rhs="0.9" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="Start" To="Idle/Idle1" TimeInSec="0" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Op="AlwaysTrue" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="Idle/Any" To="Move" TimeInSec="0.2" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="speed" Op="Greater" Rhs="0.95" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition Name="Attack" From="Idle/Any" To="Attack/Attack" TimeInSec="0.1" Sync="Restart" Curve="Smooth">
            <Priority xsi:nil="true" />
          </Transition>
          <Transition Name="Attack" From="Move" To="Attack/Attack" TimeInSec="0.1" Sync="Restart" Curve="Smooth">
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="Attack/Any" To="Idle/Any" TimeInSec="0.2" Sync="Restart" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="@animationfinished" Op="Equal" Rhs="1" />
                <Condition Lhs="speed" Op="Less" Rhs="1.5" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
          <Transition From="Attack/Any" To="Move" TimeInSec="0.1" Sync="NoSynchonization" Curve="Smooth">
            <Conditions>
              <Conjunction>
                <Condition Lhs="speed" Op="GreaterOrEqual" Rhs="1.5" />
                <Condition Lhs="@animationfinished" Op="Equal" Rhs="0.9" />
              </Conjunction>
            </Conditions>
            <Priority xsi:nil="true" />
          </Transition>
        </Transitions>
      </StateMachine>
      <StateMachine>
        <Name>SMIdle</Name>
        <Nodes>
          <Node>
            <Name>Idle1</Name>
            <AnimationTree>
              <EdPos>
                <X>-95</X>
                <Y>0</Y>
              </EdPos>
              <Child xsi:type="MyObjectBuilder_AnimationTreeNodeTrack">
                <EdPos>
                  <X>143</X>
