    <!-- OrganicPlasma — Schwarm, immer -->
    <SpawnGroup>
      <Id><TypeId>SpawnGroupDefinition</TypeId><SubtypeId>PB-Creature-OrganicPlasma</SubtypeId></Id>
      <Description>
