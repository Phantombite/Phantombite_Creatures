<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <SpawnGroups>

    <!-- Shark — selten, Apex, nur nachts -->
    <SpawnGroup>
      <Id><TypeId>SpawnGroupDefinition</TypeId><SubtypeId>PB-Creature-Shark</SubtypeId></Id>
      <Description>
        [Modular Encounters SpawnGroup]
        [AdminSpawnOnly:false]
        [PlanetWhitelist:Sulvax]
        [IgnoreCleanupRules:true]
        [CreatureSpawn:true]
        [CreatureIds:Shark]
        [UseDayOrNightOnly:true]
        [SpawnOnlyAtNight:true]
        [MinCreatureCount:1]
        [MaxCreatureCount:2]
        [MinCreatureDistance:100]
        [MaxCreatureDistance:400]
      </Description>
      <IsPirate>true</IsPirate>
      <Frequency>3.0</Frequency>
      <Prefabs>
        <Prefab SubtypeId="MES-CreaturePrefabDummy">
          <Position><X>0.0</X><Y>0.0</Y><Z>0.0</Z></Position>
          <Speed>25</Speed><Behaviour></Behaviour>
        </Prefab>
      </Prefabs>
    </SpawnGroup>

    <!-- Groump — mittel, nur nachts -->
